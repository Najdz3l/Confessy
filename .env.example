# Discord Bot Configuration
# Copy this file to .env and fill in your values

# Your Discord Bot Token
# Get it from: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Channel ID where confessions will be posted
# Enable Developer Mode in Discord settings, then right-click the channel and copy ID
CONFESSION_CHANNEL_ID=123456789

# Channel ID where confession logs will be stored (for moderation)
# This should be a private channel that only moderators can see
LOGS_CHANNEL_ID=987654321
